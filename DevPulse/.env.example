# PostgreSQL Connection
ConnectionStrings__PostgresConnection=Host=localhost;Port=5432;Database=devpulse;Username=postgres;Password=postgres

# JWT Configuration
JwtSettings__Secret=your-super-secret-key-change-this-in-production-at-least-32-chars
JwtSettings__ExpirationMinutes=60

# GitHub Integration
GitHub__Token=your-github-personal-access-token
GitHub__ClientId=your-github-oauth-client-id
GitHub__ClientSecret=your-github-oauth-client-secret

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=https://localhost:7294
